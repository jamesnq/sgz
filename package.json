    "react-hook-form": "7.45.4",
    "react-toastify": "^11.0.5",
    "request-ip": "^3.3.0",
    "sharp": "0.32.6",
    "slugify": "^1.6.6",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-essentials": "^10.0.4",
